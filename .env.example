# Copy this file to `.env` and fill in your own key:
#     cp .env.example .env
#
# The agent uses Google's Gemini via langchain-google-genai, which reads
# GOOGLE_API_KEY from the environment automatically. Get a key from
# https://aistudio.google.com/apikey . Never commit your real key —
# `.env` is gitignored.

GOOGLE_API_KEY=your-google-api-key-here

# Optional: override the default Gemini model used by the agent.
# gemini-2.5-flash is recommended here. Note the free-tier request quota is
# PER MODEL per day; if you exhaust it, prefer a different API key/account over
# switching model (gemini-2.0-flash has no free quota, and gemini-2.5-flash-lite
# returns an empty answer after tool calls in this agent).
# GOOGLE_MODEL=gemini-2.5-flash
